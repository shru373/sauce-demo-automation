<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo UI Suite" verbose="1">

  <listeners>
    <listener class-name="com.saucedemo.listeners.ScreenshotListener"/>
  </listeners>

  <test name="Login">
    <classes>
      <class name="com.saucedemo.tests.LoginTest"/>
    </classes>
  </test>

  <test name="Cart">
    <classes>
      <class name="com.saucedemo.tests.CartTest"/>
    </classes>
  </test>

  <test name="Product sorting">
    <classes>
      <class name="com.saucedemo.tests.ProductSortTest"/>
    </classes>
  </test>

  <test name="Menu">
    <classes>
      <class name="com.saucedemo.tests.MenuTest"/>
    </classes>
  </test>

  <test name="Checkout">
    <classes>
      <class name="com.saucedemo.tests.CheckoutTest"/>
    </classes>
  </test>

  <test name="Checkout validation">
    <classes>
      <class name="com.saucedemo.tests.CheckoutValidationTest"/>
    </classes>
  </test>

</suite>
